# 复制为 turnserver.conf 后修改域名、IP、密钥路径；勿提交含真实密钥的文件。
# coturn 文档：https://github.com/coturn/coturn/wiki/turnserver
# 与 USKing 配合：use-auth-secret + static-auth-secret，与 TURN_SHARED_SECRET 一致。

# --- 网络与监听 ---
# 云主机 NAT 场景推荐填写机器内网 IP；公网 IP 通过 external-ip 宣告给客户端。
listening-ip=YOUR_PRIVATE_IPV4
relay-ip=YOUR_PRIVATE_IPV4
# 云主机 NAT 场景推荐写成 公网/内网；若机器直接持有公网 IP，可仅填公网 IP。
external-ip=YOUR_PUBLIC_IPV4/YOUR_PRIVATE_IPV4

listening-port=3478
no-tls
no-dtls

# --- 可选：若你有独立 443/TLS TURN 需求，再启用下列配置 ---
# tls-listening-port=5349
# cert=/etc/letsencrypt/live/turn.example.com/fullchain.pem
# pkey=/etc/letsencrypt/live/turn.example.com/privkey.pem

# --- 认证（TURN REST / long-term，与 USKing TURN_SHARED_SECRET 一致）---
realm=turn.example.com
server-name=turn.example.com
fingerprint
use-auth-secret
static-auth-secret=REPLACE_WITH_SAME_AS_TURN_SHARED_SECRET

# --- 中继端口段（须与安全组/防火墙一致）---
min-port=50000
max-port=54999

# --- 安全基线 ---
no-cli
no-multicast-peers
stale-nonce=600

# 进程用户（包安装时常见为 turnserver）
# proc-user=turnserver
# proc-group=turnserver

# 日志（排障时可改为 verbose）
verbose
simple-log
