# ========== 生产必填 ==========
# 随机密钥，用于 JWT（至少 32 字符，勿用默认值）
# 生成示例: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 生产必须关闭开发模式（设为 false）
DEV_MODE=false

# 数据库（生产建议 PostgreSQL）
# SQLite 示例（单机）:
# DATABASE_URL=sqlite:///./data/meiguwang.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/usking

DATABASE_URL=sqlite:///./meiguwang.db

# 管理员初始密码（仅在首次创建 admin 用户时使用；已存在则忽略）
MEIGUWANG_ADMIN_PASSWORD=

# ========== 可选：支付 ==========
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ========== 可选：邮件 ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ========== 可选：AI 客服 ==========
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ========== 可选：上传大小（MB）==========
MAX_UPLOAD_MB=15

# ========== 可选：上传目录（Docker/生产挂载卷，须绝对路径）==========
# UPLOAD_DIR=/data/uploads
