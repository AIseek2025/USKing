# ========== 生产必填 ==========
# 随机密钥，用于 JWT（至少 32 字符，勿用默认值）
# 生成示例: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 生产必须关闭开发模式（设为 false）
DEV_MODE=false

# 数据库（生产建议 PostgreSQL）
# SQLite 示例（单机）:
# DATABASE_URL=sqlite:///./data/meiguwang.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/usking

DATABASE_URL=sqlite:///./meiguwang.db

# 管理员初始密码（仅在首次创建 admin 用户时使用；已存在则忽略）
MEIGUWANG_ADMIN_PASSWORD=

# ========== 可选：支付 ==========
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ========== 可选：邮件 ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ========== 可选：AI 客服 ==========
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ========== 可选：上传大小（MB）==========
MAX_UPLOAD_MB=15

# ========== 可选：上传目录（Docker/生产挂载卷，须绝对路径）==========
# UPLOAD_DIR=/data/uploads

# ========== 可选：美股数据面板（FRED / 资讯 / SEC）==========
# FRED：不填则自动使用官网公开 CSV；填写后走官方 API（元数据更完整）
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# NewsAPI: https://newsapi.org（仅开发环境可用免费层；生产请查阅许可）
NEWSAPI_KEY=
# 合规 RSS 源 URL，逗号分隔（须遵守各站 ToS；可与 news-please 等配合做正文清洗）
# NEWS_RSS_URLS=https://example.com/feed.xml
NEWS_RSS_URLS=
# 设为 1 可关闭「零配置」内置 SEC 新闻稿 RSS（无 NewsAPI 且无上面 RSS 时）
# NEWS_RSS_DISABLE_BUILTIN=1
# SEC 要求可识别 User-Agent；避免在 UA 字符串里写 https://（易被 403），用邮箱即可
# SEC_HTTP_USER_AGENT=USKing/1.0 (YourCompany contact@yoursite.com)

# ========== 可选：公司投研频道（免费注册 API Key）==========
# Finnhub: https://finnhub.io/register
# FINNHUB_API_KEY=
# Alpha Vantage: https://www.alphavantage.co/support/#api-key（有日调用限额）
# ALPHA_VANTAGE_API_KEY=

# ========== 可选：直播媒体平面（全球级重构）==========
# 推荐：站内互动用全球托管 RTC；公播/录制走 HLS/CDN + 录制供应商
# 仓库已支持 hybrid delivery（互动 RTC / 公播 HLS / legacy fallback）
LIVE_VENDOR_STACK=livekit_cloud_mux
LIVE_INTERACTIVE_VENDOR=livekit_cloud
LIVE_BROADCAST_VENDOR=global_hls_cdn
LIVE_RECORDING_VENDOR=mux
LIVE_MEDIA_BACKEND=livekit
LIVE_PUBLISH_MODE=webrtc
LIVE_PLAYBACK_MODE=webrtc
LIVE_FALLBACK_ENABLED=true
LIVE_FALLBACK_MODE=legacy_jpeg
LIVE_DEFAULT_VIEWER_INTENT=auto
LIVE_MIGRATION_MODE=managed_hybrid
LIVE_INTERACTIVE_ROLLOUT_PERCENT=100
LIVE_INTERACTIVE_AUTHENTICATED_ONLY=false
# LIVE_CANARY_USERS=alice,bob
# LIVE_FORCE_INTERACTIVE_USERS=trader001
# LIVE_FORCE_BROADCAST_COUNTRIES=CN
# LIVE_CANARY_COUNTRIES=US,SG

# 信令服务（若拆成独立 realtime 服务，填其公开地址）
LIVE_SIGNALING_URL=

# HLS 回放 / 公播 CDN 源地址，例如 https://cdn.example.com/live
LIVE_HLS_BASE_URL=
# HLS 本地输出目录（若业务应用自身承接 origin，可设为 /data/live-hls）
# LIVE_HLS_OUTPUT_DIR=/data/live-hls
# 多区域 HLS base，可选 JSON：{"us":"https://us-cdn.example.com/live","apac":"https://apac-cdn.example.com/live"}
# LIVE_HLS_REGION_BASE_URLS={"us":"https://us-cdn.example.com/live","apac":"https://apac-cdn.example.com/live","default":"https://cdn.example.com/live"}

# TURN 地址，逗号分隔，例如 turn:turn.example.com:3478?transport=udp（旧字段，可选保留）
LIVE_TURN_URLS=
# 多区域 TURN，可选 JSON：{"us":["turn:us-turn.example.com:3478?transport=udp"],"apac":["turn:apac-turn.example.com:3478?transport=udp"]}
# LIVE_TURN_REGION_URLS={"us":["turn:us-turn.example.com:3478?transport=udp"],"apac":["turn:apac-turn.example.com:3478?transport=udp"]}

# 独立 coturn（推荐生产）：与 coturn 的 static-auth-secret 一致；由后端签发 ice_servers（username/credential）
# 详见 infra/turn/README.md
TURN_ENABLED=false
TURN_REALM=turn.example.com
TURN_SHARED_SECRET=
TURN_UDP_URL=turn:turn.example.com:3478?transport=udp
# 若未部署独立 TURNS(5349/443)，留空即可；实战验证中 UDP TURN 已足够跑通跨网音视频。
TURN_TLS_URL=
TURN_CREDENTIAL_TTL_SECONDS=86400
# 可选：额外公共 STUN，逗号分隔；推荐至少保留一个稳定公共 STUN 以拿到 srflx 候选
TURN_STUN_URLS=stun:stun.l.google.com:19302

# LiveKit（推荐媒体平面之一；与 LiveKit Server 使用相同 API Key / Secret 签发 JWT）
LIVEKIT_WS_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Egress 回调共享密钥；用于 POST /api/live/egress/event
# LIVE_EGRESS_WEBHOOK_SECRET=
# 可选：多区域 RTC 接入点 JSON。未配置时统一走 LIVEKIT_WS_URL。
# LIVE_RTC_REGION_WS_URLS={"us":"wss://us-rtc.example.com","eu":"wss://eu-rtc.example.com","apac":"wss://apac-rtc.example.com","default":"wss://global-rtc.example.com"}
# 可选：国家到区域覆盖，例如 {"CN":"apac","BR":"us"}
# LIVE_REGION_HINT_MAP={"CN":"apac"}

# Redis Presence / Playback Session（推荐生产启用）
# REDIS_URL=redis://redis:6379/0

# PostgreSQL 示例（与上方 DATABASE_URL 配套）
# DATABASE_URL=postgresql+psycopg://usking:change-me@postgres:5432/usking
