# ========== 生产必填 ==========
# 随机密钥，用于 JWT（至少 32 字符，勿用默认值）
# 生成示例: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 生产必须关闭开发模式（设为 false）
DEV_MODE=false

# 数据库（生产建议 PostgreSQL）
# SQLite 示例（单机）:
# DATABASE_URL=sqlite:///./data/meiguwang.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/usking

DATABASE_URL=sqlite:///./meiguwang.db

# 管理员初始密码（仅在首次创建 admin 用户时使用；已存在则忽略）
MEIGUWANG_ADMIN_PASSWORD=

# ========== 可选：支付 ==========
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ========== 可选：邮件 ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ========== 可选：AI 客服 ==========
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ========== 可选：上传大小（MB）==========
MAX_UPLOAD_MB=15

# ========== 可选：上传目录（Docker/生产挂载卷，须绝对路径）==========
# UPLOAD_DIR=/data/uploads

# ========== 可选：美股数据面板（FRED / 资讯 / SEC）==========
# FRED：不填则自动使用官网公开 CSV；填写后走官方 API（元数据更完整）
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# NewsAPI: https://newsapi.org（仅开发环境可用免费层；生产请查阅许可）
NEWSAPI_KEY=
# 合规 RSS 源 URL，逗号分隔（须遵守各站 ToS；可与 news-please 等配合做正文清洗）
# NEWS_RSS_URLS=https://example.com/feed.xml
NEWS_RSS_URLS=
# 设为 1 可关闭「零配置」内置 SEC 新闻稿 RSS（无 NewsAPI 且无上面 RSS 时）
# NEWS_RSS_DISABLE_BUILTIN=1
# SEC 要求可识别 User-Agent；避免在 UA 字符串里写 https://（易被 403），用邮箱即可
# SEC_HTTP_USER_AGENT=USKing/1.0 (YourCompany contact@yoursite.com)

# ========== 可选：公司投研频道（免费注册 API Key）==========
# Finnhub: https://finnhub.io/register
# FINNHUB_API_KEY=
# Alpha Vantage: https://www.alphavantage.co/support/#api-key（有日调用限额）
# ALPHA_VANTAGE_API_KEY=
